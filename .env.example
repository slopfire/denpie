# Optional. Reserved for SQLx compile-time query validation if query macros are added.
DATABASE_URL="sqlite://denpie.db"

# Local server defaults.
# DENPIE_BIND_ADDR="127.0.0.1:3017"
# DENPIE_DATA_DIR="."
# DENPIE_SCHEMA_PATH="schema.sql"
# DENPIE_FRONTEND_DIST="frontend/dist"
# DENPIE_STATIC_DIR="static"
# DENPIE_SKIP_FRONTEND_BUILD="1"

# WebAuthn / Passkey Configuration (required for Docker/reverse-proxy deploys)
# Must match the HTTPS origin users open in the browser.
# DENPIE_RP_ID="denpie.com"
# DENPIE_RP_ORIGIN="https://denpie.com"
# DENPIE_RP_EXTRA_ORIGINS="https://www.denpie.com"
# PUBLIC_URL is accepted as an alias for DENPIE_RP_ORIGIN (common on PaaS).
# Secure session cookies are enabled when DENPIE_RP_ORIGIN uses https, or when DENPIE_PROD is set.
# DENPIE_PROD="1"

# NOTE: LLM credentials (API key, base URL, model) are NOT configured here.
# They are managed through the dashboard and stored in SQLite user settings.
# settings.yaml is intentionally excluded from version control.
